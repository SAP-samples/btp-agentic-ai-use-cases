# ─────────────────────────────────────────────────────────────────────────────
# a2a-client-service — Local development environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Cloud Foundry these variables are injected automatically via VCAP_SERVICES.
# ─────────────────────────────────────────────────────────────────────────────

# Server bind settings (optional — defaults shown)
PORT=3000
HOST=0.0.0.0

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# SAP BTP Destination Service (local simulation)
# ─────────────────────────────────────────────────────────────────────────────
# The SAP Cloud SDK reads VCAP_SERVICES at runtime in CF.
# For local development, create a `default-env.json` in the project root
# with the service binding credentials exported from your CF space:
#   cf create-service destination lite a2a-destination-service
#   cf create-service-key a2a-destination-service dest-sk
#   cf service-key a2a-destination-service dest-sk
#
# Then create default-env.json:
# {
#   "VCAP_SERVICES": {
#     "destination": [{
#       "name": "a2a-destination-service",
#       "credentials": {
#         "clientid": "...",
#         "clientsecret": "...",
#         "uri": "https://destination-configuration.cfapps.<region>.hana.ondemand.com",
#         "url": "https://<subaccount>.authentication.<region>.hana.ondemand.com"
#       }
#     }]
#   }
# }
#
# The SDK automatically picks up default-env.json when NODE_ENV != 'production'.
